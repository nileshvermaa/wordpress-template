<?xml version="1.0"?>
<ruleset name="Lumen Wellness">
	<description>Security, i18n and PHP-compatibility checks for the themes in this repo.</description>

	<file>lumen-wellness</file>

	<arg name="extensions" value="php"/>
	<arg name="basepath" value="."/>
	<arg name="parallel" value="8"/>
	<arg value="ps"/>

	<!-- High-value, high-confidence checks. Expand toward WordPress-Extra over time. -->
	<rule ref="WordPress.Security"/>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="lumen-wellness"/>
			</property>
		</properties>
	</rule>

	<!-- Minimum supported PHP version. -->
	<config name="testVersion" value="7.4-"/>
	<rule ref="PHPCompatibilityWP"/>
</ruleset>
